{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CMake Debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/MyApp.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: Build Debug",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${env:PATH};D:/game/vcpkg/installed/x64-windows/bin"
                }
            ],
            "console": "integratedTerminal"
        }
    ]
}